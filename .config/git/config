[core]
	preloadIndex = true
	hooksPath = ~/.config/git/hooks
[init]
	defaultBranch = main
[status]
	branch = true
	short = true
	showStash = true
	showUntrackedFiles = all
[diff]
	algorithm = histogram
	context = 3
	tool = nvim
	mnemonicPrefix = true
[difftool]
	prompt = false
[difftool "nvim"]
	cmd = nvim -d "$LOCAL" "$REMOTE"
[commit]
	gpgsign = true
[push]
	autoSetupRemote = true
	followTags = true
[pull]
	rebase = true
[rebase]
	autoStash = true
[fetch]
	prune = true
[tag]
	gpgSign = true
[alias]
	dotfiles = !git --git-dir=$HOME/.dotfiles --work-tree=$HOME
